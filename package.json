{
  "name": "deferlytics",
  "version": "0.1.0",
  "description": "Performance-first delayed analytics bootstrapper for GA4 and Yandex Metrica",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bootstrap": "./dist/bootstrap.iife.js",
    "./loader": "./dist/loader.iife.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "analytics",
    "performance",
    "typescript",
    "ga4",
    "google-analytics",
    "yandex-metrica",
    "web-vitals",
    "consent"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeleRn/deferlytics.git"
  },
  "bugs": {
    "url": "https://github.com/CeleRn/deferlytics/issues"
  },
  "homepage": "https://github.com/CeleRn/deferlytics#readme",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "jsdom": "^24.1.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
